3.1 Total number of logs
SELECT COUNT(*) AS total_logs FROM logs;
+------------+
| total_logs |
+------------+
| 5          |
+------------+


SELECT source_ip, COUNT(*) AS requests
FROM logs
GROUP BY source_ip
ORDER BY requests DESC;
